# Copy to .env for local development. On Railway, set these in each service's Variables tab.
DATABASE_URL=postgresql://user:password@host:port/railway
JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-another-long-random-string
ALLOWED_ORIGINS=http://localhost:5500,https://your-frontend.up.railway.app
FRONTEND_URL=http://localhost:5500
# Google sign-in (create at console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/auth/google/callback
